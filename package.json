{
  "name": "kratos",
  "version": "0.1.0",
  "description": "Destroy dead code ruthlessly.",
  "author": "JeremyDev87",
  "type": "module",
  "files": [
    "src",
    "LICENSE",
    "README.md",
    "README.en.md",
    "README.es.md",
    "README.ja.md",
    "README.zh-CN.md"
  ],
  "homepage": "https://github.com/JeremyDev87/kratos#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JeremyDev87/kratos.git"
  },
  "bugs": {
    "url": "https://github.com/JeremyDev87/kratos/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/JeremyDev87"
  },
  "bin": {
    "kratos": "./src/cli.js"
  },
  "scripts": {
    "scan": "node ./src/cli.js scan",
    "report": "node ./src/cli.js report",
    "clean": "node ./src/cli.js clean",
    "smoke": "node ./src/cli.js scan ./fixtures/demo-app && node ./src/cli.js report ./fixtures/demo-app/.kratos/latest-report.json",
    "test": "node --test",
    "pack:check": "npm pack --dry-run --cache ./.npm-cache",
    "verify": "npm test && npm run smoke && npm run pack:check",
    "prepublishOnly": "npm run verify"
  },
  "keywords": [
    "cli",
    "dead-code",
    "cleanup",
    "react",
    "nextjs",
    "analysis"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
