{
  "name": "@jeremyfellaz/kratos",
  "version": "0.3.3",
  "description": "Destroy dead code ruthlessly.",
  "author": "JeremyDev87",
  "type": "module",
  "files": [
    "bin",
    "LICENSE",
    "README.md",
    "README.en.md",
    "README.es.md",
    "README.ja.md",
    "README.zh-CN.md"
  ],
  "homepage": "https://github.com/JeremyDev87/kratos#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JeremyDev87/kratos.git"
  },
  "bugs": {
    "url": "https://github.com/JeremyDev87/kratos/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/JeremyDev87"
  },
  "bin": {
    "kratos": "./bin/kratos.js"
  },
  "scripts": {
    "scan": "cargo run -p kratos-cli -- scan",
    "report": "cargo run -p kratos-cli -- report",
    "clean": "cargo run -p kratos-cli -- clean",
    "smoke": "node --test test/package-smoke.test.js",
    "test": "node --test test/npm-launcher.test.js test/package-smoke.test.js",
    "pack:check": "npm pack --dry-run --cache ./.npm-cache",
    "verify": "npm test && npm run pack:check",
    "prepublishOnly": "npm run verify"
  },
  "keywords": [
    "cli",
    "dead-code",
    "cleanup",
    "react",
    "nextjs",
    "analysis"
  ],
  "optionalDependencies": {
    "@jeremyfellaz/kratos-darwin-arm64": "0.3.3",
    "@jeremyfellaz/kratos-darwin-x64": "0.3.3",
    "@jeremyfellaz/kratos-linux-x64-gnu": "0.3.3",
    "@jeremyfellaz/kratos-linux-arm64-gnu": "0.3.3",
    "@jeremyfellaz/kratos-win32-x64-msvc": "0.3.3"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
